digraph ParcelFlowContainers {
  graph [bgcolor="transparent", rankdir=LR, pad="0.25", nodesep="0.4", ranksep="0.65"];
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=12, margin="0.18,0.12", color="#167b6a", fillcolor="#eaf7f4", fontcolor="#093d35"];
  edge [color="#557a78", penwidth=1.4, arrowsize=0.7, fontname="Arial", fontsize=10];
  client [label="Web / Mobile\nClient"];
  api [label="Order API\nvalidate + create"];
  db [label="PostgreSQL\norders + outbox", shape=cylinder, fillcolor="#eef5ff", color="#2369a6", fontcolor="#102e4a"];
  relay [label="Outbox Relay"];
  broker [label="Event Broker\nOrderCreated", shape=hexagon, fillcolor="#fff1f3", color="#cc071e", fontcolor="#7d0012"];
  billing [label="Billing Worker\ncreate invoice"];
  notification [label="Notification Worker\nsend message"];
  otel [label="OpenTelemetry\ncollector", fillcolor="#f0edfb", color="#6846a5", fontcolor="#342055"];
  client -> api;
  api -> db;
  db -> relay;
  relay -> broker;
  broker -> billing;
  broker -> notification;
  api -> otel [style=dashed, label=" telemetry"];
  billing -> otel [style=dashed];
  notification -> otel [style=dashed];
}
