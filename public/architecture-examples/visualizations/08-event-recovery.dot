digraph EventRecovery {
  graph [bgcolor="transparent", rankdir=LR, pad="0.25", nodesep="0.35", ranksep="0.6"];
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=12, margin="0.16,0.1", color="#167b6a", fillcolor="#eaf7f4", fontcolor="#093d35"];
  edge [color="#557a78", penwidth=1.5, arrowsize=0.7, fontname="Arial", fontsize=10];
  committed [label="Delivery + outbox\ncommitted"];
  published [label="Event published"];
  processing [label="Consumer processing"];
  completed [label="Business effect\ncompleted"];
  retry [label="Backoff retry", fillcolor="#fff8e8", color="#b7791f", fontcolor="#3f2d00"];
  dlq [label="DLQ + investigation", fillcolor="#fff1f3", color="#cc071e", fontcolor="#7d0012"];
  committed -> published -> processing -> completed;
  processing -> retry [label=" transient failure"];
  retry -> processing [label=" redelivery"];
  processing -> dlq [label=" repeated / invalid"];
  dlq -> processing [label=" corrected replay"];
}
